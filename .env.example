# Server
PORT=3000
NODE_ENV=development

# Contact endpoint
# Default recipient is info@thepointcr.com when CONTACT_TO is omitted.
CONTACT_TO=info@thepointcr.com

# Option A: Send email through Resend.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
# CONTACT_FROM=The Point CR <hello@thepointcr.com>

# Option B: Forward submissions to your own webhook.
# CONTACT_WEBHOOK_URL=https://example.com/contact-webhook
